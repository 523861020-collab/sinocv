{
  "manifest_version": 3,
  "name": "SINOCV CRM",
  "version": "2.0",
  "description": "Complete CRM for truck export — contacts, PI, reminders, follow-up",
  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions": ["https://web.whatsapp.com/*", "https://truck-export-pi-xi.vercel.app/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["https://web.whatsapp.com/*"],
    "js": ["content.js"],
    "css": ["sidebar.css"]
  }],
  "action": {
    "default_title": "SINOCV CRM"
  }
}
