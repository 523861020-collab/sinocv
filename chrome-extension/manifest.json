{
  "manifest_version": 3,
  "name": "SINOCV CRM",
  "version": "5.0",
  "description": "XINYUNTONG CRM — injected into WhatsApp Web",
  "permissions": ["storage"],
  "host_permissions": [
    "*://web.whatsapp.com/*",
    "https://truckmarts.com/*"
  ],
  "content_scripts": [{
    "matches": ["*://web.whatsapp.com/*"],
    "js": ["content.js"],
    "run_at": "document_end"
  }]
}
